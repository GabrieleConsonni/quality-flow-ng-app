{
  "name": "quality-flow-ng-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start:mock-auth": "pnpm run lint && pnpm run compile-styles && ng serve quality-flow-ng-app --configuration=mock-auth --port=4400",
    "start:mock-auth-vulki": "pnpm run lint && pnpm run compile-styles && ng serve quality-flow-ng-app --configuration=mock-auth-vulki --port=4400",
    "start-alkyra-theme": "pnpm run lint && pnpm run compile-styles && ng serve quality-flow-ng-app --configuration=development-alkyra --port=4400",
    "start-vulki-theme": "pnpm run lint && pnpm run compile-styles && ng serve quality-flow-ng-app --configuration=development-vulki --port=4400",
    "code-format": "biome check --write \"apps/quality-flow-ng-app/src/app\"",
    "lint": "biome lint \"apps/quality-flow-ng-app/src/app\"",
    "compile-styles": "sass --load-path=node_modules apps/quality-flow-ng-app/src/assets/vulki/styles/main.scss apps/quality-flow-ng-app/src/assets/vulki/styles/main.css --no-source-map && sass --load-path=node_modules apps/quality-flow-ng-app/src/assets/alkyra/styles/main.scss apps/quality-flow-ng-app/src/assets/alkyra/styles/main.css --no-source-map",
    "styles-build:development": "pnpm run compile-styles && ng build quality-flow-ng-app --configuration=development",
    "styles-build:mock-auth": "pnpm run compile-styles && ng build quality-flow-ng-app --configuration=mock-auth",
    "styles-build:production": "pnpm run compile-styles && ng build quality-flow-ng-app --configuration=production",
    "build": "ng build quality-flow-ng-app",
    "watch": "ng build quality-flow-ng-app --watch --configuration development",
    "watch:mock-auth": "ng build quality-flow-ng-app --watch --configuration=mock-auth",
    "test": "ng test quality-flow-ng-app --watch=false",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:run": "playwright test -c e2e/playwright.config.ts",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@angular/animations": "~20.3.15",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "~20.3.15",
    "@angular/compiler": "~20.3.15",
    "@angular/core": "~20.3.15",
    "@angular/forms": "~20.3.15",
    "@angular/platform-browser": "~20.3.15",
    "@angular/platform-browser-dynamic": "~20.3.15",
    "@angular/router": "~20.3.15",
    "@ngrx/component-store": "~20.1.0",
    "@ngrx/operators": "~20.1.0",
    "@ngrx/signals": "~20.1.0",
    "@ngx-translate/core": "~16.0.4",
    "@ngx-translate/http-loader": "~16.0.1",
    "angular-oauth2-oidc": "~18.0.0",
    "devextreme": "~24.2.10",
    "devextreme-angular": "~24.2.10",
    "jsondiffpatch": "^0.7.3",
    "monaco-editor": "^0.54.0",
    "ngx-monaco-editor-v2": "^20.0.0",
    "rxjs": "~7.8.2",
    "tslib": "~2.3.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~20.3.13",
    "@angular-devkit/core": "~20.3.13",
    "@angular-devkit/schematics": "~20.3.13",
    "@angular/build": "~20.3.15",
    "@angular/cli": "~20.3.13",
    "@angular/compiler-cli": "~20.3.15",
    "@biomejs/biome": "2.4.10",
    "@playwright/test": "^1.58.2",
    "@schematics/angular": "~20.3.13",
    "@types/node": "^25.1.0",
    "devextreme-cli": "latest",
    "devextreme-themebuilder": "~24.2.10",
    "sass": "~1.96.0",
    "typescript": "~5.9.3",
    "vitest": "^3.1.1"
  }
}
